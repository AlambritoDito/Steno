{
  "name": "steno",
  "version": "0.1.0",
  "description": "Real-time local transcription for classes & meetings",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:python": "bash scripts/build-python.sh",
    "build:electron": "electron-builder --mac",
    "build": "npm run build:python && npm run build:electron"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.steno.app",
    "productName": "Steno",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "darkModeSupport": false,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Steno needs microphone access for real-time transcription."
      }
    },
    "dmg": {
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "iconSize": 100,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 175,
          "y": 170,
          "type": "file"
        },
        {
          "x": 485,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "extraResources": [
      {
        "from": "dist/steno-server",
        "to": "steno-server"
      }
    ],
    "files": [
      "electron/**/*"
    ]
  }
}
