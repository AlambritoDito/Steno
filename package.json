{
  "name": "steno",
  "version": "0.1.0",
  "description": "Real-time local transcription for classes & meetings",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:python": "bash scripts/build-python.sh",
    "build:electron": "electron-builder --mac",
    "build": "npm run build:python && npm run build:electron"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.steno.app",
    "productName": "Steno",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "extraResources": [
      {
        "from": "dist/steno-server",
        "to": "steno-server"
      }
    ],
    "files": [
      "electron/**/*"
    ]
  }
}
